import { useState, useRef } from 'react';
import { motion, AnimatePresence } from 'framer-motion';
import { useQuery, useMutation, useQueryClient } from '@tanstack/react-query';
import { useForm } from 'react-hook-form';
import { zodResolver } from '@hookform/resolvers/zod';
import { z } from 'zod';
import { format } from 'date-fns';
import { Camera, Edit2, Loader2, User as UserIcon, Compass, ChevronDown, ChevronUp, Sparkles, X, ChevronRight } from 'lucide-react';
import * as Dialog from '@radix-ui/react-dialog';
import { toast } from 'sonner';
import { supabase } from '../lib/supabase';
import { useAuthStore } from '../store/useAuthStore';
import { useAppStore } from '../store/useAppStore';

const profileSchema = z.object({
  full_name: z.string().min(1, 'µ░ÅÕÉŹŃéÆÕģźÕŖøŃüŚŃü”ŃüÅŃüĀŃüĢŃüä'),
  full_name_kana: z.string().optional(),
  gender: z.enum(['Male', 'Female', 'Other']).optional().nullable(),
  mssv: z.string().optional(),
  university_email: z.string().email('µ£ēÕŖ╣Ńü¬ŃāĪŃā╝Ńā½ŃéóŃāēŃā¼Ńé╣ŃéÆÕģźÕŖøŃüŚŃü”ŃüÅŃüĀŃüĢŃüä').optional().or(z.literal('')),
  phone: z.string().optional(),
  line_nickname: z.string().optional(),
  line_id: z.string().optional(),
  hometown: z.string().optional(),
  nationality: z.string().optional(),export default function Profile() {
  const queryClient = useQueryClient();
  const { currentUser } = useAuthStore();
  const { selectedYear } = useAppStore();
  const fileInputRef = useRef<HTMLInputElement>(null);
  const [modalOpen, setModalOpen] = useState(false);
  const [showFullProfile, setShowFullProfile] = useState(false);
  const [isSidebarVisible, setIsSidebarVisible] = useState(true);

  // 1. Fetch Profile Data (Join with current year's membership)
  const { data: profileData, isLoading: isProfileLoading } = useQuery({
    queryKey: ['profile', currentUser?.id, selectedYear?.id],
    queryFn: async () => {
      if (!currentUser || !selectedYear) return null;

      const { data: user, error } = await supabase
        .from('users')
        .select(`*, club_memberships(*)`)
        .eq('id', currentUser.id)
        .eq('club_memberships.academic_year_id', selectedYear.id)
        .single();

      if (error) throw error;
      return user;
    },
    enabled: !!currentUser && !!selectedYear,
  });

  const activeMembership = profileData?.club_memberships?.[0] || null;

  // 2. Edit Profile Info Mutation
  const { register, handleSubmit } = useForm<ProfileFormData>({
    resolver: zodResolver(profileSchema),
    values: {
      full_name: profileData?.full_name || '',
      full_name_kana: profileData?.full_name_kana || '',
      gender: profileData?.gender || null,
      mssv: profileData?.mssv || '',
      university_email: profileData?.university_email || '',
      phone: profileData?.phone || '',
      line_nickname: profileData?.line_nickname || '',
      line_id: profileData?.line_id || '',
      hometown: profileData?.hometown || '',
      nationality: profileData?.nationality || '',
    }
  });

  const updateProfileMutation = useMutation({
    mutationFn: async (data: ProfileFormData) => {
      const { error } = await supabase
        .from('users')
        .update({
          full_name: data.full_name,
          full_name_kana: data.full_name_kana,
          gender: data.gender,
          mssv: data.mssv,
          university_email: data.university_email,
          phone: data.phone,
          line_nickname: data.line_nickname,
          line_id: data.line_id,
          hometown: data.hometown,
          nationality: data.nationality,
        })
        .eq('id', currentUser!.id);

      if (error) throw error;
    },
    onSuccess: () => {
      toast.success('ŃāŚŃāŁŃāĢŃéŻŃā╝Ńā½ŃéÆµø┤µ¢░ŃüŚŃüŠŃüŚŃü¤ŃĆé');
      queryClient.invalidateQueries({ queryKey: ['profile', currentUser?.id] });
      setModalOpen(false);
    },
    onError: (err: any) => {
      toast.error('Ńé©Ńā®Ńā╝ŃüīńÖ║ńö¤ŃüŚŃüŠŃüŚŃü¤: ' + err.message);
    }
  });

  // 3. Avatar Upload Mutation
  const avatarMutation = useMutation({
    mutationFn: async (file: File) => {
      if (file.size > 2 * 1024 * 1024) throw new Error('ńö╗ÕāÅŃü«ŃéĄŃéżŃé║Ńü»2MBõ╗źõĖŗŃü½ŃüŚŃü”ŃüÅŃüĀŃüĢŃüä');
      if (!['image/jpeg', 'image/png'].includes(file.type)) throw new Error('.jpg ŃüŠŃü¤Ńü» .png ÕĮóÕ╝ÅŃü«ńö╗ÕāÅŃü«Ńü┐ŃéóŃāāŃāŚŃāŁŃā╝ŃāēÕÅ»ĶāĮŃü¦ŃüÖ');

      const fileExt = file.name.split('.').pop();
      const fileName = `${currentUser!.id}_${Date.now()}.${fileExt}`;
      const filePath = `${fileName}`;

      const { error: uploadError } = await supabase.storage
        .from('avatars')
        .upload(filePath, file);

      if (uploadError) throw uploadError;

      const { data: { publicUrl } } = supabase.storage
        .from('avatars')
        .getPublicUrl(filePath);

      const { error: updateError } = await supabase
        .from('users')
        .update({ avatar_url: publicUrl })
        .eq('id', currentUser!.id);

      if (updateError) throw updateError;
    },
    onSuccess: () => {
      toast.success('ŃāŚŃāŁŃāĢŃéŻŃā╝Ńā½ńö╗ÕāÅŃéÆµø┤µ¢░ŃüŚŃüŠŃüŚŃü¤');
      queryClient.invalidateQueries({ queryKey: ['profile', currentUser?.id] });
      if (fileInputRef.current) fileInputRef.current.value = '';
    },
    onError: (err: any) => {
      toast.error('ŃéóŃāāŃāŚŃāŁŃā╝ŃāēŃé©Ńā®Ńā╝: ' + err.message);
      if (fileInputRef.current) fileInputRef.current.value = '';
    }
  });

  const handleAvatarChange = (e: React.ChangeEvent<HTMLInputElement>) => {
    if (e.target.files && e.target.files.length > 0) {
      avatarMutation.mutate(e.target.files[0]);
    }
  };

  // 4. Fetch Registrations History
  const { data: historyData, isLoading: isHistoryLoading } = useQuery({
    queryKey: ['user-history', currentUser?.id, selectedYear?.id],
    queryFn: async () => {
      if (!currentUser || !selectedYear) return [];

      const { data, error } = await supabase
        .from('registrations')
        .select(`
          *,
          activities!inner(*)
        `)
        .eq('user_id', currentUser.id)
        .eq('activities.academic_year_id', selectedYear.id);

      if (error) throw error;
      return data.sort((a: any, b: any) => new Date(b.activities.date).getTime() - new Date(a.activities.date).getTime());
    },
    enabled: !!currentUser && !!selectedYear,
  });

  if (isProfileLoading) {
    return (
      <div className="flex justify-center items-center h-[calc(100vh-4.5rem)] bg-[#FDFDFD]">
        <Loader2 className="w-8 h-8 text-[#4F5BD5] animate-spin" />
      </div>
    );
  }

  if (!profileData) return null;

  return (
    <div className="h-[calc(100vh-4.5rem)] bg-[#FDFDFD] overflow-hidden relative font-sans">
      
      {/* 5. Modern Sidebar Trigger (Subtle Chevron) */}
      <AnimatePresence>
        {!isSidebarVisible && (
          <motion.button
            initial={{ opacity: 0, x: -10 }}
            animate={{ opacity: 1, x: 0 }}
            exit={{ opacity: 0, x: -10 }}
            onClick={() => setIsSidebarVisible(true)}
            className="absolute left-4 top-1/2 -translate-y-1/2 z-50 w-10 h-10 bg-white border border-stone-200 text-stone-400 rounded-full flex items-center justify-center shadow-sm hover:text-indigo-600 hover:border-indigo-100 transition-all group"
          >
            <ChevronRight className="w-5 h-5 group-hover:translate-x-0.5 transition-transform" />
          </motion.button>
        )}
      </AnimatePresence>

      <div className="h-full flex overflow-hidden">

        {/* 6. Refined Sidebar: Clean Typography & Balanced Spacing */}
        <motion.aside 
          animate={{ 
            width: isSidebarVisible ? (window.innerWidth < 1024 ? '100%' : 400) : 0,
            opacity: isSidebarVisible ? 1 : 0,
            x: isSidebarVisible ? 0 : -400
          }}
          transition={{ type: "spring", damping: 30, stiffness: 300 }}
          className={`bg-white border-r border-stone-100 flex flex-col z-20 shrink-0 overflow-hidden relative ${
            window.innerWidth < 1024 ? 'absolute inset-y-0 left-0 max-w-full' : ''
          }`}
        >
          {/* Close Button UI Fix */}
          <button 
            onClick={() => setIsSidebarVisible(false)}
            className="absolute top-6 right-6 p-2 text-stone-300 hover:text-stone-900 transition-colors z-30 lg:hidden"
          >
            <X className="w-5 h-5" />
          </button>
          
          <button 
            onClick={() => setIsSidebarVisible(false)}
            className="hidden lg:flex absolute top-6 right-6 p-2 text-stone-200 hover:text-stone-400 transition-colors z-30"
          >
            <ChevronRight className="w-5 h-5 rotate-180" />
          </button>

          <div className="flex-1 flex flex-col p-10 lg:p-12 overflow-y-auto scrollbar-none">
            {/* Profile Identity - Centered & Spacious */}
            <div className="flex flex-col items-center mb-12">
              <div className="relative mb-8">
                <div className="w-32 h-32 rounded-[2.5rem] overflow-hidden bg-stone-50 border-[5px] border-white shadow-[0_30px_60px_-12px_rgba(0,0,0,0.12)] hover:scale-[1.02] transition-all duration-500 transform-gpu relative">
                  {profileData.avatar_url ? (
                    <img src={profileData.avatar_url} alt="Avatar" className="w-full h-full object-cover" />
                  ) : (
                    <div className="w-full h-full flex items-center justify-center text-stone-200 bg-[#F9FAFB]">
                      <UserIcon className="w-14 h-14" />
                    </div>
                  )}
                  <div
                    className={`absolute inset-0 bg-black/30 backdrop-blur-[2px] flex items-center justify-center opacity-0 hover:opacity-100 transition-all cursor-pointer ${avatarMutation.status === 'pending' ? 'opacity-100' : ''}`}
                    onClick={() => avatarMutation.status !== 'pending' && fileInputRef.current?.click()}
                  >
                    {avatarMutation.status === 'pending' ? (
                      <Loader2 className="w-6 h-6 text-white animate-spin" />
                    ) : (
                      <Camera className="w-6 h-6 text-white" />
                    )}
                  </div>
                </div>
                <input type="file" accept="image/*" ref={fileInputRef} onChange={handleAvatarChange} className="hidden" />

                {/* Role Badge - Modern Minimalist */}
                {activeMembership && (
                  <div className="absolute -bottom-3 left-1/2 -translate-x-1/2 px-5 py-1.5 bg-[#4F5BD5] text-white text-[10px] font-black uppercase tracking-[0.2em] rounded-2xl shadow-xl shadow-indigo-200/50 whitespace-nowrap">
                    {activeMembership.role === 'admin' ? 'ń«ĪńÉåĶĆģ' :
                      activeMembership.role === 'executive' ? 'Õ╣╣ķā©' :
                        activeMembership.role === 'alumni' ? 'OB/OG' : 'ŃāĪŃā│ŃāÉŃā╝'}
                  </div>
                )}
              </div>

              <div className="text-center space-y-2">
                <h2 className="text-3xl font-black tracking-tight text-stone-900">{profileData.full_name}</h2>
                <p className="text-sm font-bold text-stone-300 uppercase tracking-[0.15em]">{profileData.full_name_kana || 'No Name Kana'}</p>
              </div>
            </div>

            {/* Profile Info Details - Clean Editorial Grid */}
            <div className="space-y-10 pt-10 border-t border-stone-50">
              <div className="flex items-center justify-between">
                <span className="text-[11px] font-black uppercase tracking-[0.25em] text-indigo-600">Profile Details</span>
                <button 
                  onClick={() => setShowFullProfile(!showFullProfile)}
                  className="text-stone-300 hover:text-stone-900 transition-colors"
                >
                  {showFullProfile ? <ChevronUp className="w-4 h-4" /> : <ChevronDown className="w-4 h-4" />}
                </button>
              </div>

              <motion.div 
                animate={{ height: showFullProfile ? 'auto' : '180px' }}
                className="overflow-hidden space-y-8"
              >
                <div className="grid grid-cols-2 gap-y-8 gap-x-4">
                  <div className="space-y-1.5">
                    <label className="text-[9px] font-black uppercase tracking-widest text-stone-400">ÕŁ”ń▒ŹńĢ¬ÕÅĘ</label>
                    <p className="text-sm font-bold text-stone-700">{profileData.mssv || 'ŌĆö'}</p>
                  </div>
                  <div className="space-y-1.5">
                    <label className="text-[9px] font-black uppercase tracking-widest text-stone-400">ÕŁ”Õ╣┤</label>
                    <p className="text-sm font-bold text-stone-700">{activeMembership?.university_year ? `${activeMembership.university_year}Õ╣┤` : 'ŌĆö'}</p>
                  </div>
                  <div className="space-y-1.5">
                    <label className="text-[9px] font-black uppercase tracking-widest text-stone-400">µĆ¦Õłź</label>
                    <p className="text-sm font-bold text-stone-700">
                      {profileData.gender === 'Male' ? 'ńöĘµĆ¦' : profileData.gender === 'Female' ? 'Õź│µĆ¦' : profileData.gender === 'Other' ? 'ŃüØŃü«õ╗¢' : 'ŌĆö'}
                    </p>
                  </div>
                  <div className="space-y-1.5">
                    <label className="text-[9px] font-black uppercase tracking-widest text-stone-400">Õć║Ķ║½Õ£░</label>
                    <p className="text-sm font-bold text-stone-700 truncate">{profileData.hometown || 'ŌĆö'}</p>
                  </div>
                </div>

                <div className="space-y-8 pt-4">
                  <div className="space-y-1.5">
                    <label className="text-[9px] font-black uppercase tracking-widest text-stone-400">Õż¦ÕŁ”ŃāĪŃā╝Ńā½</label>
                    <p className="text-[13px] font-bold text-stone-700 truncate">{profileData.university_email || 'ŌĆö'}</p>
                  </div>
                  <div className="space-y-1.5">
                    <label className="text-[9px] font-black uppercase tracking-widest text-stone-400">ķĆŻńĄĪńö©ŃāĪŃā╝Ńā½</label>
                    <p className="text-[13px] font-bold text-stone-700 truncate">{profileData.email}</p>
                  </div>
                  <div className="grid grid-cols-2 gap-4">
                    <div className="space-y-1.5">
                      <label className="text-[9px] font-black uppercase tracking-widest text-stone-400">LINE Name</label>
                      <p className="text-sm font-bold text-stone-700 truncate">{profileData.line_nickname || 'ŌĆö'}</p>
                    </div>
                    <div className="space-y-1.5">
                      <label className="text-[9px] font-black uppercase tracking-widest text-stone-400">ķø╗Ķ®▒ńĢ¬ÕÅĘ</label>
                      <p className="text-sm font-bold text-stone-700">{profileData.phone || 'ŌĆö'}</p>
                    </div>
                  </div>
                </div>
              </motion.div>
            </div>
            
            {/* Action Section - Fixed hierarchy */}
            <div className="mt-auto pt-12">
              <Dialog.Root open={modalOpen} onOpenChange={setModalOpen}>
                <Dialog.Trigger asChild>
                  <button className="w-full flex items-center justify-center gap-3 px-8 py-4 bg-stone-900 group hover:bg-black text-white text-[13px] font-black rounded-[1.25rem] transition-all shadow-xl shadow-stone-200 active:scale-95">
                    <Edit2 className="w-4 h-4 group-hover:rotate-12 transition-transform" />
                    µāģÕĀ▒ŃéÆńĘ©ķøåŃüÖŃéŗ
                  </button>
                </Dialog.Trigger>
                <Dialog.Portal>
                  <Dialog.Overlay className="fixed inset-0 bg-black/10 backdrop-blur-sm z-[100]" />
                  <Dialog.Content className="fixed left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[92%] max-w-xl bg-white border border-stone-100 p-8 lg:p-12 shadow-2xl rounded-[3rem] z-[101] max-h-[90vh] overflow-y-auto scrollbar-none">
                    <Dialog.Title className="text-3xl font-black tracking-tight text-stone-900 mb-10">µāģÕĀ▒Ńü«ńĘ©ķøå</Dialog.Title>
                    <form onSubmit={handleSubmit((d) => updateProfileMutation.mutate(d))} className="space-y-8">
                      <div className="grid grid-cols-1 sm:grid-cols-2 gap-6">
                        <div className="space-y-2">
                          <label className="text-[10px] font-black uppercase tracking-widest text-stone-400 ml-1">µ░ÅÕÉŹ (µ╝óÕŁŚ/Romaji)</label>
                          <input {...register('full_name')} className="w-full h-14 bg-stone-50/50 border-none rounded-2xl px-6 text-sm font-bold text-stone-900 focus:ring-2 focus:ring-indigo-500/20 transition-all" />
                        </div>
                        <div className="space-y-2">
                          <label className="text-[10px] font-black uppercase tracking-widest text-stone-400 ml-1">ŃāĢŃā¬Ńé¼ŃāŖ</label>
                          <input {...register('full_name_kana')} className="w-full h-14 bg-stone-50/50 border-none rounded-2xl px-6 text-sm font-bold text-stone-900 focus:ring-2 focus:ring-indigo-500/20 transition-all" />
                        </div>
                      </div>

                      <div className="grid grid-cols-1 sm:grid-cols-2 gap-6">
                        <div className="space-y-2">
                          <label className="text-[10px] font-black uppercase tracking-widest text-stone-400 ml-1">ÕŁ”ń▒ŹńĢ¬ÕÅĘ</label>
                          <input {...register('mssv')} className="w-full h-14 bg-stone-50/50 border-none rounded-2xl px-6 text-sm font-bold text-stone-400" disabled />
                        </div>
                        <div className="space-y-2">
                          <label className="text-[10px] font-black uppercase tracking-widest text-stone-400 ml-1">µĆ¦Õłź</label>
                          <select {...register('gender')} className="w-full h-14 bg-stone-50/50 border-none rounded-2xl px-6 text-sm font-bold text-stone-900 focus:ring-2 focus:ring-indigo-500/20 transition-all appearance-none cursor-pointer">
                            <option value="">ķüĖµŖ×ŃüŚŃü”ŃüÅŃüĀŃüĢŃüä</option>
                            <option value="Male">ńöĘµĆ¦</option>
                            <option value="Female">Õź│µĆ¦</option>
                            <option value="Other">ŃüØŃü«õ╗¢</option>
                          </select>
                        </div>
                      </div>

                      <div className="space-y-2">
                        <label className="text-[10px] font-black uppercase tracking-widest text-stone-400 ml-1">Õż¦ÕŁ”ŃāĪŃā╝Ńā½ŃéóŃāēŃā¼Ńé╣</label>
                        <input {...register('university_email')} className="w-full h-14 bg-stone-50/50 border-none rounded-2xl px-6 text-sm font-bold text-stone-900 focus:ring-2 focus:ring-indigo-500/20 transition-all" />
                      </div>

                      <div className="grid grid-cols-1 sm:grid-cols-2 gap-6">
                        <div className="space-y-2">
                          <label className="text-[10px] font-black uppercase tracking-widest text-stone-400 ml-1">LINEŃāŗŃāāŃé»ŃāŹŃā╝ŃāĀ</label>
                          <input {...register('line_nickname')} className="w-full h-14 bg-stone-50/50 border-none rounded-2xl px-6 text-sm font-bold text-stone-900 focus:ring-2 focus:ring-indigo-500/20 transition-all" />
                        </div>
                        <div className="space-y-2">
                          <label className="text-[10px] font-black uppercase tracking-widest text-stone-400 ml-1">ķø╗Ķ®▒ńĢ¬ÕÅĘ</label>
                          <input {...register('phone')} className="w-full h-14 bg-stone-50/50 border-none rounded-2xl px-6 text-sm font-bold text-stone-900 focus:ring-2 focus:ring-indigo-500/20 transition-all" />
                        </div>
                      </div>

                      <div className="pt-8 flex justify-end gap-4 sticky bottom-0 bg-white pb-2">
                        <Dialog.Close asChild>
                          <button type="button" className="px-8 py-3 text-stone-400 text-sm font-black hover:text-stone-900 transition-colors">ķ¢ēŃüśŃéŗ</button>
                        </Dialog.Close>
                        <button
                          type="submit"
                          disabled={updateProfileMutation.status === 'pending'}
                          className="px-12 py-4 bg-indigo-600 hover:bg-indigo-700 text-white text-[13px] font-black rounded-2xl transition-all shadow-xl shadow-indigo-100 active:scale-95 flex items-center gap-3"
                        >
                          {updateProfileMutation.status === 'pending' && <Loader2 className="w-4 h-4 animate-spin" />}
                          µø┤µ¢░ŃéÆõ┐ØÕŁś
                        </button>
                      </div>
                    </form>
                  </Dialog.Content>
                </Dialog.Portal>
              </Dialog.Root>
            </div>
          </div>
        </motion.aside>

        {/* 7. Main Content: Activity Dashboard - Harmonized Colors */}
        <motion.main 
          layout
          transition={{ type: "spring", damping: 32, stiffness: 200 }}
          className="flex-1 flex flex-col overflow-hidden bg-[#FAFAFA]"
        >
          {/* Enhanced Header - Glassmorphism */}
          <header className="px-8 lg:px-12 py-8 lg:py-10 flex items-center justify-between border-b border-stone-100 bg-white/40 backdrop-blur-xl shrink-0 z-10 transition-all">
            <div className="flex items-center gap-5 lg:gap-6">
              <div className="w-12 h-12 lg:w-14 lg:h-14 rounded-2xl bg-white shadow-sm flex items-center justify-center text-indigo-600 border border-stone-50">
                <Sparkles className="w-6 h-6" />
              </div>
              <div className="space-y-0.5">
                <h3 className="text-xl lg:text-2xl font-black tracking-tight text-stone-900">Activity History</h3>
                <p className="text-[10px] lg:text-xs font-bold text-stone-300 uppercase tracking-[0.2em]">µ┤╗ÕŗĢŃü«Ķ©śķī▓</p>
              </div>
            </div>

            <div className="flex flex-col items-end">
              <span className="text-[9px] font-black uppercase tracking-widest text-stone-300 mb-1">Academic Year</span>
              <div className="px-4 py-1.5 bg-stone-900 text-white text-[10px] font-black rounded-full shadow-lg shadow-stone-100 uppercase tracking-widest">
                {selectedYear?.name}
              </div>
            </div>
          </header>

          {/* Activity List Section */}
          <div className="flex-1 overflow-y-auto px-8 lg:px-20 py-12 scrollbar-thin scrollbar-thumb-stone-100">
            {isHistoryLoading ? (
              <div className="h-full flex justify-center items-center">
                <Loader2 className="w-10 h-10 text-indigo-600/10 animate-spin" />
              </div>
            ) : historyData && historyData.length > 0 ? (
              <div className="grid grid-cols-1 xl:grid-cols-2 gap-8">
                {historyData.map((reg: any, index: number) => {
                  const activity = reg.activities;
                  const isPresent = reg.attendance_status === 'present';
                  const isMissing = reg.attendance_status === 'unexcused_absence';
                  const isExcused = reg.attendance_status === 'excused_absence';

                  return (
                    <motion.div
                      key={reg.id}
                      initial={{ opacity: 0, y: 30 }}
                      animate={{ opacity: 1, y: 0 }}
                      transition={{ delay: index * 0.05, duration: 0.8, ease: [0.22, 1, 0.36, 1] }}
                      className="group bg-white border border-stone-100/60 p-8 rounded-[2rem] hover:shadow-[0_40px_80px_-20px_rgba(0,0,0,0.06)] hover:border-indigo-100/50 transition-all duration-700 relative overflow-hidden"
                    >
                      {/* Status Accent Strip - Horizontal Top */}
                      <div className={`absolute top-0 left-0 right-0 h-1.5 ${isPresent ? 'bg-emerald-400' :
                        isMissing ? 'bg-rose-400' :
                          isExcused ? 'bg-amber-400' : 'bg-indigo-300'
                        }`} />

                      <div className="flex justify-between items-start mb-6">
                        <div className="space-y-2">
                          <div className="inline-flex items-center gap-2 px-3 py-1 bg-stone-50 rounded-lg">
                            <Compass className="w-3.5 h-3.5 text-stone-300" />
                            <span className="text-[10px] font-black text-stone-400 tracking-widest uppercase">
                              {format(new Date(activity.date), 'yyyy.MM.dd')}
                            </span>
                          </div>
                          <h4 className="text-xl font-black text-stone-900 leading-tight group-hover:text-indigo-600 transition-colors">
                            {activity.title}
                          </h4>
                        </div>
                        <div className={`px-5 py-2 rounded-xl text-[10px] font-black uppercase tracking-[0.1em] border ${isPresent ? 'text-emerald-500 bg-emerald-50/50 border-emerald-100/50' :
                          isMissing ? 'text-rose-500 bg-rose-50/50 border-rose-100/50' :
                            isExcused ? 'text-amber-500 bg-amber-50/50 border-amber-100/50' :
                              'text-indigo-500 bg-indigo-50/50 border-indigo-100/50'
                          }`}>
                          {isPresent ? 'Õć║ÕĖŁ' : isMissing ? 'µ¼ĀÕĖŁ' : isExcused ? 'µ¼ĀÕĖŁ(Õ▒ŖÕć║µĖł)' : 'ÕÅéÕŖĀńÖ╗ķī▓µĖł'}
                        </div>
