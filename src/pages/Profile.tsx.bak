                      <div className="flex items-center gap-8 text-[11px] font-bold text-stone-400">
                        <div className="flex items-center gap-2">
                          <div className="w-1.5 h-1.5 rounded-full bg-stone-200" />
                          {activity.location}
                        </div>
                        <div className="flex items-center gap-2">
                          <div className="w-1.5 h-1.5 rounded-full bg-stone-200" />
                          {activity.type === 'volunteer' ? 'Ńā£Ńā®Ńā│ŃāåŃéŻŃéó' : 'ŃéżŃāÖŃā│Ńāł'}
                        </div>
                      </div>

                      {reg.admin_note && (
                        <div className="mt-8 pt-8 border-t border-stone-50 flex gap-4">
                          <div className="w-1 h-full bg-indigo-50 rounded-full" />
                          <p className="text-xs text-stone-500 italic leading-relaxed py-1">
                            "{reg.admin_note}"
                          </p>
                        </div>
                      )}
                    </motion.div>
                  );
                })}
              </div>
            ) : (
              <div className="h-full flex flex-col items-center justify-center text-center max-w-lg mx-auto">
                <div className="w-32 h-32 rounded-[3.5rem] bg-white shadow-[0_30px_70px_-15px_rgba(0,0,0,0.1)] flex items-center justify-center mb-10 group hover:scale-110 transition-all duration-700">
                  <motion.div
                    animate={{ rotate: [0, 10, -10, 0] }}
                    transition={{ repeat: Infinity, duration: 4 }}
                  >
                    <Compass className="w-12 h-12 text-indigo-600/30 group-hover:text-indigo-600 transition-colors" />
                  </motion.div>
                </div>
                <h3 className="text-3xl font-black tracking-tight text-stone-900 mb-4">ÕåÆķÖ║ŃéÆÕ¦ŗŃéüŃüŠŃüŚŃéćŃüå</h3>
                <p className="text-sm font-bold text-stone-400 leading-relaxed max-w-[320px] mb-12">
                  ŃüŠŃüĀŃā£Ńā®Ńā│ŃāåŃéŻŃéóŃüĖŃü«ÕÅéÕŖĀĶ©śķī▓ŃüīŃüéŃéŖŃüŠŃüøŃéōŃĆéµ¢░ŃüŚŃüäµ┤╗ÕŗĢŃü½ÕÅéÕŖĀŃüŚŃü”ŃĆüµĆØŃüäÕć║Ńü«Ķ©śķī▓ŃéÆŃĆé
                </p>
                <button
                  onClick={() => window.location.href = '/activities'}
                  className="px-12 py-5 bg-stone-900 hover:bg-black text-white rounded-2xl font-black text-[13px] shadow-2xl shadow-stone-200 active:scale-95 transition-all group overflow-hidden relative"
                >
                  <span className="relative z-10 flex items-center gap-3">
                    µ┤╗ÕŗĢŃéÆµÄóŃüŚŃü½ĶĪīŃüÅ
